<div class="container mt-4">
  <a href="/products/{{product.id}}" class="btn btn-outline-secondary btn-sm mb-3">← Volver al detalle</a>

  <h1 class="mb-4">Editar: {{product.name}}</h1>

  <form action="/products/{{product.id}}/edit" method="POST" class="card card-body">
    <div class="mb-3">
      <label for="name" class="form-label">Nombre:</label>
      <input type="text" id="name" name="name" class="form-control{{#if errors.name}} is-invalid{{/if}}" value="{{product.name}}">
      {{#if errors.name}}
        <div class="invalid-feedback">{{errors.name}}</div>
      {{/if}}
    </div>
    <div class="mb-3">
      <label for="description" class="form-label">Descripción:</label>
      <textarea id="description" name="description" class="form-control{{#if errors.description}} is-invalid{{/if}}">{{product.description}}</textarea>
      {{#if errors.description}}
        <div class="invalid-feedback">{{errors.description}}</div>
      {{/if}}
    </div>
    <div class="mb-3">
      <label for="price" class="form-label">Precio:</label>
      <input type="number" id="price" name="price" class="form-control{{#if errors.price}} is-invalid{{/if}}" value="{{product.price}}">
      {{#if errors.price}}
        <div class="invalid-feedback">{{errors.price}}</div>
      {{/if}}
    </div>
    <button type="submit" class="btn btn-primary">Guardar cambios</button>
  </form>
</div>
