<div class="container mt-4">
  <a href="/products/{{product.id}}" class="btn btn-outline-secondary btn-sm mb-3">← Volver al detalle</a>

  <h1 class="mb-4">Editar: {{product.name}}</h1>

  <form action="/products/{{product.id}}/edit" method="POST" class="card card-body">
    <div class="mb-3">
      <label for="name" class="form-label">Nombre:</label>
      <input type="text" id="name" name="name" class="form-control" value="{{product.name}}" required>
    </div>
    <div class="mb-3">
      <label for="description" class="form-label">Descripción:</label>
      <textarea id="description" name="description" class="form-control" required>{{product.description}}</textarea>
    </div>
    <div class="mb-3">
      <label for="price" class="form-label">Precio:</label>
      <input type="number" id="price" name="price" class="form-control" value="{{product.price}}" min="0" step="1" required>
    </div>
    <button type="submit" class="btn btn-primary">Guardar cambios</button>
  </form>
</div>
